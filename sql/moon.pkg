import {
  "moonbitlang/core/int",
  "moonbitlang/core/list",
  "moonbitlang/ulex-runtime/lexbuf",
}

options(
  "pre-build": [
    {
      "command": "$mod_dir/.mooncakes/moonbitlang/yacc/moonyacc $input -o $output",
      "input": "parser.mbty",
      "output": "parser.mbt",
    },
    {
      "command": "$mod_dir/.mooncakes/moonbitlang/ulex/moonlex $input | moonfmt > $output",
      "input": "lexer.mbtx",
      "output": "lexer.mbt",
    },
  ],
)
